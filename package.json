{
  "name": "syncr",
  "version": "1.0.0",
  "private": true,
  "description": "Syncr — Discord Rich Presence for Firefox",
  "scripts": {
    "build:chrome": "bun scripts/build-chrome.js",
    "build:xpi": "web-ext build --source-dir extension --artifacts-dir dist --overwrite-dest",
    "validate:scrapers": "bun scripts/validate-scraper.js",
    "test:engine": "bun scripts/test-engine.js",
    "update": "powershell -ExecutionPolicy Bypass -File update.ps1",
    "update:host": "powershell -ExecutionPolicy Bypass -File update.ps1 -HostOnly",
    "update:setup": "powershell -ExecutionPolicy Bypass -File update.ps1 -SetupOnly",
    "release": "powershell -ExecutionPolicy Bypass -File update.ps1"
  },
  "devDependencies": {
    "adm-zip": "^0.5.18",
    "web-ext": "^8.0.0",
    "webextension-polyfill": "^0.12.0"
  }
}

{
  "name": "syncr-launcher",
  "version": "1.0.0",
  "description": "Syncr Launcher — installs and updates Syncr from GitHub",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.clawb1t.syncr",
    "productName": "Syncr",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "icon.ico"
    ],
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "requireAdministrator",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Syncr",
      "artifactName": "Syncr.exe"
    }
  }
}

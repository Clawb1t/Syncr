{
  "version": 2,
  "pollMs": 2000,
  "changeDetection": {
    "compareFields": ["mode", "context"]
  },
  "rules": [
    {
      "when": {
        "hostnameIncludes": "proton",
        "selectorExists": [
          "[data-testid=\"composer\"]",
          ".composer-container",
          ".proton-mail-composer",
          ".composer--container"
        ]
      },
      "emit": {
        "mode": "drafting",
        "context": "Drafting an email",
        "pageUrl": "https://mail.proton.me/"
      }
    },
    {
      "when": {
        "hostnameIncludes": "proton",
        "hashParamAny": ["elementID", "messageID"]
      },
      "emit": {
        "mode": "viewing",
        "context": "Viewing an email",
        "pageUrl": "https://mail.proton.me/"
      }
    },
    {
      "when": {
        "hostnameIncludes": "proton",
        "selectorExists": [
          "[data-testid=\"message-view\"]:not([hidden])",
          "[data-testid=\"conversation-view\"]:not([hidden])",
          ".message-view:not([hidden])"
        ]
      },
      "emit": {
        "mode": "viewing",
        "context": "Viewing an email",
        "pageUrl": "https://mail.proton.me/"
      }
    },
    {
      "when": {
        "hostnameIncludes": "proton",
        "pathSegmentAfter": {
          "inbox": 1,
          "drafts": 1,
          "all-drafts": 1,
          "sent": 1,
          "all-sent": 1,
          "starred": 1,
          "archive": 1,
          "spam": 1,
          "trash": 1,
          "all-mail": 1,
          "almost-all-mail": 1,
          "newsletters": 1
        }
      },
      "emit": {
        "mode": "viewing",
        "context": "Viewing an email",
        "pageUrl": "https://mail.proton.me/"
      }
    },
    {
      "when": {
        "hostnameIncludes": "proton",
        "pathSegmentAfter": {
          "inbox": 0,
          "drafts": 0,
          "all-drafts": 0,
          "sent": 0,
          "all-sent": 0,
          "starred": 0,
          "archive": 0,
          "spam": 0,
          "trash": 0,
          "all-mail": 0,
          "almost-all-mail": 0,
          "newsletters": 0
        }
      },
      "emit": {
        "mode": "browsing",
        "context": "Browsing folder",
        "pageUrl": "https://mail.proton.me/"
      }
    },
    {
      "when": {
        "hostnameIncludes": "proton",
        "pathIncludes": "/all-drafts"
      },
      "emit": { "mode": "browsing", "context": "Browsing drafts", "pageUrl": "https://mail.proton.me/" }
    },
    {
      "when": {
        "hostnameIncludes": "proton",
        "pathIncludes": "/drafts"
      },
      "emit": { "mode": "browsing", "context": "Browsing drafts", "pageUrl": "https://mail.proton.me/" }
    },
    {
      "when": {
        "hostnameIncludes": "proton",
        "pathIncludes": "/all-sent"
      },
      "emit": { "mode": "browsing", "context": "Browsing sent mail", "pageUrl": "https://mail.proton.me/" }
    },
    {
      "when": {
        "hostnameIncludes": "proton",
        "pathIncludes": "/sent"
      },
      "emit": { "mode": "browsing", "context": "Browsing sent mail", "pageUrl": "https://mail.proton.me/" }
    },
    {
      "when": {
        "hostnameIncludes": "proton",
        "pathIncludes": "/starred"
      },
      "emit": { "mode": "browsing", "context": "Browsing starred mail", "pageUrl": "https://mail.proton.me/" }
    },
    {
      "when": {
        "hostnameIncludes": "proton",
        "pathIncludes": "/archive"
      },
      "emit": { "mode": "browsing", "context": "Browsing archive", "pageUrl": "https://mail.proton.me/" }
    },
    {
      "when": {
        "hostnameIncludes": "proton",
        "pathIncludes": "/spam"
      },
      "emit": { "mode": "browsing", "context": "Browsing spam", "pageUrl": "https://mail.proton.me/" }
    },
    {
      "when": {
        "hostnameIncludes": "proton",
        "pathIncludes": "/trash"
      },
      "emit": { "mode": "browsing", "context": "Browsing trash", "pageUrl": "https://mail.proton.me/" }
    },
    {
      "when": {
        "hostnameIncludes": "proton",
        "pathIncludes": ["/all-mail", "/almost-all-mail"]
      },
      "emit": { "mode": "browsing", "context": "Browsing all mail", "pageUrl": "https://mail.proton.me/" }
    },
    {
      "when": {
        "hostnameIncludes": "proton",
        "pathIncludes": "/newsletters"
      },
      "emit": { "mode": "browsing", "context": "Browsing newsletters", "pageUrl": "https://mail.proton.me/" }
    },
    {
      "when": {
        "hostnameIncludes": "proton",
        "pathIncludes": "/inbox"
      },
      "emit": { "mode": "browsing", "context": "Browsing inbox", "pageUrl": "https://mail.proton.me/" }
    },
    {
      "when": {
        "hostnameIncludes": "proton",
        "pathIncludes": "/u/"
      },
      "emit": { "mode": "browsing", "context": "Browsing emails", "pageUrl": "https://mail.proton.me/" }
    }
  ],
  "default": {
    "emit": {
      "mode": "browsing",
      "context": "Browsing emails",
      "pageUrl": "https://mail.proton.me/"
    }
  }
}

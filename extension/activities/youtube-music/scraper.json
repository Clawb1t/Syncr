{
  "version": 2,
  "pollMs": 2000,
  "events": ["yt-navigate-finish"],
  "changeDetection": {
    "seekThreshold": 5,
    "compareFields": ["title", "artist", "paused", "albumArt", "videoId"],
    "playbackFields": { "time": "currentTime", "paused": "paused" }
  },
  "rules": [
    {
      "extract": {
        "title": { "selectorText": ".title.ytmusic-player-bar" },
        "subtitle": { "selectorText": ".subtitle.ytmusic-player-bar" },
        "artist": { "split": { "source": "{subtitle}", "sep": " • ", "index": 0 } },
        "album": { "split": { "source": "{subtitle}", "sep": " • ", "index": 1 } },
        "albumArtRaw": { "selectorAttr": { "selector": "img.ytmusic-player-bar", "attr": "src" } },
        "albumArt": {
          "regexReplace": {
            "source": "{albumArtRaw}",
            "pattern": "=w\\d+-h\\d+.*$",
            "replacement": "=w500-h500"
          }
        },
        "songLinkHref": {
          "coalesce": [
            { "selectorAttr": { "selector": "ytmusic-player-bar a[href*=\"watch?v=\"]", "attr": "href" } },
            { "selectorAttr": { "selector": "a.ytp-title-link.yt-uix-sessionlink", "attr": "href" } },
            { "selectorAttr": { "selector": ".title.ytmusic-player-bar a", "attr": "href" } }
          ]
        },
        "videoId": {
          "coalesce": [
            { "urlParam": "v" },
            {
              "regexReplace": {
                "source": "{songLinkHref}",
                "pattern": "[?&]v=([^&]+)",
                "replacement": "$1"
              }
            },
            {
              "regexReplace": {
                "source": "{albumArtRaw}",
                "pattern": "/vi/([^/]+)/",
                "replacement": "$1"
              }
            }
          ]
        },
        "playback": { "video": { "selector": "video", "minReadyState": 2 } }
      },
      "require": ["title", "playback"],
      "emit": {
        "title": "{title}",
        "artist": "{artist}",
        "album": "{album}",
        "albumArt": "{albumArt}",
        "videoId": "{videoId}",
        "currentTime": "{playback.currentTime}",
        "duration": "{playback.duration}",
        "paused": "{playback.paused}",
        "pageUrl": "https://music.youtube.com/watch?v={videoId}"
      }
    }
  ],
  "fallback": {
    "emit": { "browsing": true }
  },
  "default": { "emit": { "browsing": true } }
}

{
  "manifest_version": 2,
  "name": "Syncr",
  "version": "1.0.11",
  "description": "Display what you're doing in Firefox as Discord Rich Presence.",
  "author": "Syncr Contributors",

  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },

  "permissions": [
    "tabs",
    "activeTab",
    "nativeMessaging",
    "storage"
  ],

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "Syncr",
    "default_icon": "icons/icon.svg"
  },

  "background": {
    "scripts": ["background/background.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["*://music.youtube.com/*"],
      "js": ["activities/youtube-music/content-script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["activities/youtube/content-script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://www.reddit.com/*", "*://old.reddit.com/*"],
      "js": ["activities/reddit/content-script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://mail.proton.me/*", "*://mail.protonmail.com/*"],
      "js": ["activities/proton-mail/content-script.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    "icons/icon.svg",
    "activities/registry.json",
    "activities/*/metadata.json",
    "activities/*/logo.png",
    "activities/*/logo.svg",
    "activities/*/logo.jpg",
    "activities/*/logo.webp"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "syncr@clawb1t",
      "strict_min_version": "91.0",
      "update_url": "https://raw.githubusercontent.com/Clawb1t/Syncr/main/updates.json",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}

{
  "manifest_version": 2,
  "name": "Syncr",
  "version": "1.0.20",
  "description": "Display what you're doing in Firefox as Discord Rich Presence.",
  "author": "Syncr Contributors",

  "syncr": {
    "engineVersion": "2.0.0"
  },

  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },

  "permissions": [
    "tabs",
    "activeTab",
    "nativeMessaging",
    "storage"
  ],

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "Syncr",
    "default_icon": "icons/icon.svg"
  },

  "background": {
    "scripts": ["background/background.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": [
        "activities/_runtime/engine/context.js",
        "activities/_runtime/engine/when.js",
        "activities/_runtime/engine/emit.js",
        "activities/_runtime/engine/change-detection.js",
        "activities/_runtime/engine/helpers.js",
        "activities/_runtime/engine/fetch.js",
        "activities/_runtime/engine/extract.js",
        "activities/_runtime/engine/evaluate.js",
        "activities/_runtime/universal.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    "icons/icon.svg",
    "activities/registry.json",
    "activities/*/metadata.json",
    "activities/*/logo.png",
    "activities/*/logo.svg",
    "activities/*/logo.jpg",
    "activities/*/scraper.json"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "syncr@clawb1t",
      "strict_min_version": "91.0",
      "update_url": "https://raw.githubusercontent.com/Clawb1t/Syncr/main/updates.json",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  }
}
